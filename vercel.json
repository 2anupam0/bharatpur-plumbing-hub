{
  "version": 2,
  "installCommand": "pip install -r requirements.txt",
  "buildCommand": "SECRET_KEY=build-key DJANGO_SETTINGS_MODULE=plumbing_shop.settings python manage.py collectstatic --noinput",
  "framework": null,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
